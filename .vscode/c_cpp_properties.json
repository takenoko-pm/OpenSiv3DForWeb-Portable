{
    "configurations": [
        {
            "name": "Emscripten on Windows",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/OpenSiv3D/include/Siv3D",
                "${workspaceFolder}/OpenSiv3D/include/Siv3D/ThirdParty"
            ],
            "compilerPath": "${env:EMSDK}/upstream/emscripten/emcc.bat",
            "cStandard": "c11",
            "cppStandard": "c++20",
            "intelliSenseMode": "linux-clang-x64",
            "forcedInclude": [
                "${workspaceFolder}/.vscode/Undefs.h"
            ]
        },
        {
            "name": "Emscripten on macOS/Linux",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/OpenSiv3D/include/Siv3D",
                "${workspaceFolder}/OpenSiv3D/include/Siv3D/ThirdParty"
            ],
            "compilerPath": "${env:EMSDK}/upstream/emscripten/emcc",
            "cStandard": "c11",
            "cppStandard": "c++20",
            "intelliSenseMode": "linux-clang-x64",
            "forcedInclude": [
                "${workspaceFolder}/.vscode/Undefs.h"
            ]
        }
    ],
    "version": 4
}