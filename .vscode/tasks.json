{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Compile Debug",
            "command": ".vscode/emsdk_run.bat",
            "args": [
                "emcc",
                { "value": "@.vscode/Compile.rsp", "quoting": "strong" },
                { "value": "@.vscode/Compile.Debug.rsp", "quoting": "strong" },
                { "value": "@.vscode/Link.rsp", "quoting": "strong" },
                { "value": "@.vscode/Link.Debug.rsp", "quoting": "strong" }
            ],
            "linux": {
                "command": "bash",
                "args": [
                    ".vscode/emsdk_run.sh",
                    "emcc",
                    { "value": "@.vscode/Compile.rsp", "quoting": "strong" },
                    { "value": "@.vscode/Compile.Debug.rsp", "quoting": "strong" },
                    { "value": "@.vscode/Link.rsp", "quoting": "strong" },
                    { "value": "@.vscode/Link.Debug.rsp", "quoting": "strong" }
                ]
            },
            "osx": {
                "command": "bash",
                "args": [
                    ".vscode/emsdk_run.sh",
                    "emcc",
                    { "value": "@.vscode/Compile.rsp", "quoting": "strong" },
                    { "value": "@.vscode/Compile.Debug.rsp", "quoting": "strong" },
                    { "value": "@.vscode/Link.rsp", "quoting": "strong" },
                    { "value": "@.vscode/Link.Debug.rsp", "quoting": "strong" }
                ]
            }
        },
        {
            "type": "shell",
            "label": "Compile Release",
            "command": ".vscode/emsdk_run.bat",
            "args": [
                "emcc",
                { "value": "@.vscode/Compile.rsp", "quoting": "strong" },
                { "value": "@.vscode/Compile.Release.rsp", "quoting": "strong" },
                { "value": "@.vscode/Link.rsp", "quoting": "strong" },
                { "value": "@.vscode/Link.Release.rsp", "quoting": "strong" }
            ],
            "linux": {
                "command": "bash",
                "args": [
                    ".vscode/emsdk_run.sh",
                    "emcc",
                    { "value": "@.vscode/Compile.rsp", "quoting": "strong" },
                    { "value": "@.vscode/Compile.Release.rsp", "quoting": "strong" },
                    { "value": "@.vscode/Link.rsp", "quoting": "strong" },
                    { "value": "@.vscode/Link.Release.rsp", "quoting": "strong" }
                ]
            },
            "osx": {
                "command": "bash",
                "args": [
                    ".vscode/emsdk_run.sh",
                    "emcc",
                    { "value": "@.vscode/Compile.rsp", "quoting": "strong" },
                    { "value": "@.vscode/Compile.Release.rsp", "quoting": "strong" },
                    { "value": "@.vscode/Link.rsp", "quoting": "strong" },
                    { "value": "@.vscode/Link.Release.rsp", "quoting": "strong" }
                ]
            }
        },
        {
            "label": "Build Debug",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Compile Debug",
                "Compress Output"
            ],
            "group":{
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Build Release",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Compile Release",
                "Compress Output"
            ],
            "group": "build"
        },
        {
            "type": "shell",
            "label": "Compress Output",
            "command": ".vscode/emsdk_run.bat",
            "args": [
                "node",
                ".vscode/Compress.mjs", "index.wasm"
            ],
            "linux": {
                 "command": "bash",
                 "args": [
                    ".vscode/emsdk_run.sh",
                    "node",
                    ".vscode/Compress.mjs",
                    "index.wasm"
                    ]
                },
            "osx": {
                "command": "bash",
                "args": [
                    ".vscode/emsdk_run.sh",
                    "node",
                    ".vscode/Compress.mjs",
                    "index.wasm"
                    ]
                },
            "group": "none"
        },
        {
            "type": "shell",
            "label": "Run Local Server and Open Browser",
            "command": ".vscode/emsdk_run.bat",
            "args": [
                "emrun",
                "--hostname", "localhost",
                "--port", "8080",
                "index.html"
            ],
            "linux": { 
                "command": "bash",
                "args": [
                    ".vscode/emsdk_run.sh",
                    "emrun",
                    "--hostname",
                    "localhost",
                    "--port",
                    "8080",
                    "index.html"
                    ]
                },
            "osx": {
                "command": "bash",
                "args": [
                    ".vscode/emsdk_run.sh",
                    "emrun",
                    "--hostname",
                    "localhost",
                    "--port",
                    "8080",
                    "index.html"
                    ]
                },
            "group": "none"
        },
        {
            "type": "shell",
            "label": "Run Local Server",
            "command": ".vscode/emsdk_run.bat",
            "args": [
                "emrun",
                "--hostname", "localhost",
                "--port", "8080",
                "--no_browser",
                "index.html"
            ],
            "linux": {
                "command": "bash",
                "args": [
                    ".vscode/emsdk_run.sh",
                    "emrun",
                    "--hostname",
                    "localhost",
                    "--port",
                    "8080",
                    "--no_browser",
                    "index.html"
                    ]
                },
            "osx": {
                "command": "bash",
                "args": [
                    ".vscode/emsdk_run.sh",
                    "emrun",
                    "--hostname",
                    "localhost",
                    "--port",
                    "8080",
                    "--no_browser",
                    "index.html"
                    ]
                },
            "isBackground": true,
            "problemMatcher": [
                {
                    "pattern": [
                        {
                            "regexp": ".",
                            "file": 1,
                            "location": 2,
                            "message": 3
                        }
                    ],
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": ".",
                        "endsPattern": "Now listening at",
                    }
                }
            ],
            "group": "none"
        },
        {
            "label": "Stop Local Server",
            "type": "shell",
            "command": "echo ${input:terminate}",
            "group": "none"
        }
    ],
    "inputs": [
        {
            "id": "terminate",
            "type": "command",
            "command": "workbench.action.tasks.terminate",
            "args": "Run Local Server"
        }
    ]
}